# Production Environment Variables
# CMM Level 5 Database Configuration

# ============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================================================

# Database credentials
DB_USER=your_db_user
DB_PASSWORD=your_secure_password
DB_NAME=workdesk24_production
DB_HOST=your-database-host.com
DB_PORT=3306

# ============================================================================
# DATABASE CONNECTION POOL (PRODUCTION-OPTIMIZED)
# ============================================================================

# Connection pool size
# Recommended: (number_of_cores * 2) + effective_spindle_count
# For 4-core server: 10-50 connections
# For 8-core server: 20-100 connections
DB_POOL_MIN=10
DB_POOL_MAX=50

# Connection timeouts (milliseconds)
# How long to wait for a connection before failing
DB_POOL_ACQUIRE=30000

# How long a connection can be idle before being released
DB_POOL_IDLE=10000

# How often to check for idle connections (milliseconds)
DB_POOL_EVICT=60000

# ============================================================================
# DATABASE SSL/TLS CONFIGURATION (RECOMMENDED FOR PRODUCTION)
# ============================================================================

# Enable SSL connection
DB_SSL=true

# SSL certificate validation
DB_SSL_REJECT_UNAUTHORIZED=true

# SSL certificate paths (if using custom certificates)
# DB_SSL_CA=/path/to/ca-cert.pem
# DB_SSL_CERT=/path/to/client-cert.pem
# DB_SSL_KEY=/path/to/client-key.pem

# ============================================================================
# DATABASE MONITORING
# ============================================================================

# Health check interval (milliseconds)
# How often to check database health
DB_HEALTH_CHECK_INTERVAL=30000

# Metrics collection interval (milliseconds)
# How often to collect and log connection pool metrics
DB_METRICS_INTERVAL=60000

# Slow query threshold (milliseconds)
# Queries slower than this will be logged
SLOW_QUERY_THRESHOLD=1000

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment
NODE_ENV=production

# Server port
PORT=3000

# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============================================================================
# OPTIONAL: READ REPLICA (FOR SCALING)
# ============================================================================

# If using read replicas for scaling read operations
# DB_READ_HOST=read-replica-host.com
# DB_READ_PORT=3306
# DB_READ_USER=read_user
# DB_READ_PASSWORD=read_password

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# APM (Application Performance Monitoring)
# APM_SERVICE_NAME=workdesk24
# APM_SERVER_URL=https://apm.yourcompany.com

# Sentry (Error tracking)
# SENTRY_DSN=https://your-sentry-dsn

# ============================================================================
# CLOUD DATABASE CONFIGURATIONS
# ============================================================================

# === AWS RDS ===
# DB_HOST=your-instance.region.rds.amazonaws.com
# DB_PORT=3306
# DB_SSL=true

# === Google Cloud SQL ===
# DB_HOST=/cloudsql/project:region:instance
# DB_PORT=3306
# DB_SSL=true

# === Azure Database for MySQL ===
# DB_HOST=your-server.mysql.database.azure.com
# DB_PORT=3306
# DB_SSL=true
# DB_SSL_CA=/path/to/BaltimoreCyberTrustRoot.crt.pem

# === DigitalOcean Managed Database ===
# DB_HOST=your-cluster.db.ondigitalocean.com
# DB_PORT=25060
# DB_SSL=true

# ============================================================================
# LOAD TESTING RECOMMENDATIONS
# ============================================================================

# For development/staging (lower traffic)
# DB_POOL_MIN=5
# DB_POOL_MAX=20

# For production (moderate traffic: 100-500 req/sec)
# DB_POOL_MIN=10
# DB_POOL_MAX=50

# For production (high traffic: 500-1000 req/sec)
# DB_POOL_MIN=20
# DB_POOL_MAX=100

# For production (very high traffic: >1000 req/sec)
# DB_POOL_MIN=30
# DB_POOL_MAX=150
# Consider: Read replicas, caching, sharding

# ============================================================================
# MONITORING THRESHOLDS
# ============================================================================

# Alert when pool utilization exceeds this percentage
POOL_UTILIZATION_ALERT_THRESHOLD=80

# Alert when waiting requests exceed this count
POOL_WAITING_ALERT_THRESHOLD=10

# Alert when error count exceeds this in 5 minutes
ERROR_THRESHOLD=50

# ============================================================================
# NOTES
# ============================================================================

# 1. NEVER commit this file with actual credentials
# 2. Use secrets manager (AWS Secrets Manager, Azure Key Vault, etc.) in production
# 3. Rotate database passwords regularly
# 4. Monitor connection pool metrics in production
# 5. Adjust pool size based on actual load testing
# 6. Enable SSL/TLS for production databases
# 7. Set up database connection alerts in your monitoring system
# 8. Test graceful shutdown in staging environment
# 9. Monitor slow queries and optimize
# 10. Plan for horizontal scaling with read replicas
