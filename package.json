{
  "name": "workdesk24",
  "version": "1.0.0",
  "description": "Node.js backend with Express, Sequelize, MySQL, and JWT auth - TypeScript",
  "main": "dist/server.production.js",
  "scripts": {
    "start": "node dist/server.production.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.production.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "prestart": "npm run build",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest",
    "manualRun": "nodemon dist/server.production.js"
  },
  "keywords": [
    "express",
    "sequelize",
    "mysql",
    "jwt",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "moment-timezone": "^0.6.2",
    "multer": "^2.2.0",
    "mysql2": "^3.11.0",
    "nodemailer": "^8.0.10",
    "sequelize": "^6.37.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.5.0",
    "@types/nodemailer": "^6.4.16",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.11.0",
    "nodemon": "^3.1.4",
    "sequelize-cli": "^6.6.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
